<idea-plugin>
    <id>aurora-code</id>
    <name>Aurora</name>
    <category>UI</category>

    <vendor url="https://github.com/bxacosta/aurora-code-theme">bxacosta</vendor>

    <description><![CDATA[
        A minimalistic dark theme with clean syntax highlighting.<br>
        <em>Simple, elegant coding experience.</em>
    ]]></description>

    <change-notes><![CDATA[
        Initial release of the theme.
    ]]></change-notes>

    <!-- Platform-only dependency -> compatible with ALL JetBrains IDEs -->
    <depends>com.intellij.modules.platform</depends>

    <extensions defaultExtensionNs="com.intellij">
        <!-- id kept identical to the previous published version to preserve the theme reference -->
        <themeProvider id="aurora-code" path="/theme/aurora.theme.json"/>
    </extensions>
</idea-plugin>
